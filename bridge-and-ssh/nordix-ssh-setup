set -euo pipefail

have() { command -v "$1" >/dev/null 2>&1; }
log()  { printf "[INFO] %s\n" "$*"; }
warn() { printf "[WARN] %s\n" "$*" >&2; }

# --- self-elevate if not root (so desktop click pops a polkit dialog) ---
if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
  if have pkexec; then
    exec pkexec /bin/bash "$0" "$@"
  else
    zenity --error --title="Activate SSH" --text="Root is needed. Run with sudo."
    exit 1
  fi
fi

# Save original user for zenity later
ORIG_USER="${SUDO_USER:-$USER}"
ORIG_DISPLAY="${DISPLAY:-:0}"
ORIG_DBUS="${DBUS_SESSION_BUS_ADDRESS:-}"

# Ensure pacman db is fresh (quick)
pacman -Sy --noconfirm >/dev/null

# Install openssh if missing
if pacman -Qi openssh &>/dev/null; then
  log "openssh already installed."
else
  log "Installing openssh..."
  pacman -S --noconfirm --needed openssh >/dev/null
fi

# Enable & start sshd
log "Activating and starting sshd..."
systemctl enable sshd >/dev/null
systemctl restart sshd

# Open firewall (ufw / firewalld) if present/active
opened_rules=()

if have ufw; then
  if ufw status 2>/dev/null | grep -qi "^status: active"; then
    if ! ufw status numbered | grep -qE "^\[[ 0-9]+\]\s+22/tcp\s+ALLOW IN"; then
      ufw allow 22/tcp >/dev/null || true
      opened_rules+=("ufw: 22/tcp")
    fi
  fi
fi

if systemctl is-active --quiet firewalld && have firewall-cmd; then
  # service ssh
  firewall-cmd --quiet --query-service=ssh || {
    firewall-cmd --add-service=ssh >/dev/null
    firewall-cmd --permanent --add-service=ssh >/dev/null
    opened_rules+=("firewalld: service ssh")
  }
  # explicit port (ok if already exists)
  firewall-cmd --quiet --query-port=22/tcp || {
    firewall-cmd --add-port=22/tcp >/dev/null
    firewall-cmd --permanent --add-port=22/tcp >/dev/null
    opened_rules+=("firewalld: 22/tcp")
  }
  firewall-cmd --reload >/dev/null || true
fi

# Collect IPs (IPv4 on active ifaces, no loopback); fallback via route
get_ips() {
  ip -4 -o addr show up 2>/dev/null | awk '!/ lo / {print $4}' | cut -d/ -f1
}
get_route_ip() {
  ip route get 1.1.1.1 2>/dev/null | awk '/src/ {for(i=1;i<=NF;i++) if ($i=="src") {print $(i+1); exit}}'
}

ips="$(get_ips || true)"
[[ -z "${ips// /}" ]] && ips="$(get_route_ip || true)"
[[ -z "${ips// /}" ]] && ips="No IPv4 found."

# Pick first IP for a ready-to-copy command
first_ip="$(printf "%s\n" "$ips" | head -n1)"
user_hint="$ORIG_USER"
if [[ -n "$first_ip" ]] && [[ "$first_ip" != "No IPv4 found." ]]; then
  ssh_cmd="ssh ${user_hint}@${first_ip}"
else
  ssh_cmd="ssh <user>@<IP>"
fi

# Ensure zenity exists for GUI message (install if needed)
if ! have zenity; then
  pacman -S --noconfirm --needed zenity >/dev/null 2>&1 || true
fi

# Build message with Pango markup for bigger text
msg="<span size=\"large\"><b>SSH is activated and running!</b></span>

<span size=\"medium\"><b>IP Address:</b></span>
<span size=\"large\" font_family=\"monospace\">$ips</span>

<span size=\"medium\"><b>Connect command:</b></span>
<span size=\"large\" font_family=\"monospace\">$ssh_cmd</span>

<span size=\"small\">Copy the command above to connect from another computer.</span>"

if have zenity; then
  # Run zenity as original user to avoid Wayland permission issues
  if [[ -n "$ORIG_USER" ]] && [[ "$ORIG_USER" != "root" ]]; then
    sudo -u "$ORIG_USER" \
      DISPLAY="$ORIG_DISPLAY" \
      WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
      XDG_RUNTIME_DIR="/run/user/$(id -u "$ORIG_USER")" \
      DBUS_SESSION_BUS_ADDRESS="$ORIG_DBUS" \
      zenity --info \
        --title="SSH Activated" \
        --text="$msg" \
        --width=500 \
        --height=300 \
        --no-wrap
  else
    zenity --info \
      --title="SSH Activated" \
      --text="$msg" \
      --width=500 \
      --height=300 \
      --no-wrap
  fi
else
  # Fallback to terminal output
  echo ""
  echo "================================"
  echo "  SSH is activated and running!"
  echo "================================"
  echo ""
  echo "IP Address: $ips"
  echo "Connect:    $ssh_cmd"
  echo ""
fi
